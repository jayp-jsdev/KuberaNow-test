DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Production: https://kuberanow.com

# Allow search engines to crawl and index the site (robots.txt, sitemap, meta robots)
# Set to false on staging/preview; true in production
SEO_CRAWLING_ENABLED=false

# Trending news background job (default: every 5 minutes)
TRENDING_CRON_ENABLED=false
TRENDING_RECALC_INTERVAL_MS=300000

# Optional secret for POST/GET /api/cron/trending (recommended in production)
TRENDING_CRON_SECRET=
